# WordPress / Listivo
WP_SITE=https://casaimobiliariaes.com.br
WP_API_URL=https://casaimobiliariaes.com.br/wp-json
WP_USERNAME=
# Application Password gerada em /wp-admin/profile.php (nunca a senha real da conta)
WP_PASSWORD=
# Nome do custom post type dos imóveis no Listivo. CONFIRMADO: post type real
# é "listivo_listing", mas a URL da API usa o rest_base "listings".
WP_POST_TYPE=listings

# OLX PRO (API OAuth2)
OLX_CLIENT_ID=
OLX_CLIENT_SECRET=
# URL de callback registrada no e-mail para suporteintegrador@olxbr.com
# Ex: https://<seu-projeto>.vercel.app/api/oauth/callback
OLX_REDIRECT_URI=
# Preenchido manualmente após completar o fluxo em /api/oauth/authorize
OLX_ACCESS_TOKEN=

# Segredo compartilhado com o scheduler externo (cron-job.org, GitHub Actions)
# que chama GET /api/sync. Gere um valor aleatório qualquer.
CRON_SECRET=
